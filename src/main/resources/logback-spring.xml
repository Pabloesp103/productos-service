<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/base.xml"/>

    <springProperty scope="context" name="appName" source="spring.application.name"/>

    <appender name="cloudwatch" class="ca.pjer.logback.AwsLogsAppender">
        <layout>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </layout>
        <logGroupName>practica-microservicios</logGroupName>
        <logStreamName>${appName}</logStreamName>
        <accessKeyId>admin</accessKeyId>
        <secretAccessKey>admin</secretAccessKey>
        <region>us-east-1</region>
        <endpoint>http://localstack:4566</endpoint>
    </appender>

    <root level="INFO">
        <appender-ref ref="cloudwatch"/>
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
